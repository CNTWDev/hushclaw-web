ADMIN_PASSWORD=admin123
SECRET_KEY=change-this-to-a-random-secret-key
DATABASE_URL=sqlite:///./hushclas.db

# ── Email (OTP delivery) ────────────────────────────────────────────────────
# Leave SMTP_HOST empty to print OTP codes to the console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@hushclaw.com

# ── Auth tunables ───────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
TOKEN_EXPIRE_DAYS=30

# ── File upload ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
